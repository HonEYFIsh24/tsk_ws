<launch>
  <node name="cam_node" pkg="rgb_cam" type="cam_node" output="screen">
    <param name="cam_id" value="0"/>
    <param name="width" value="640"/>
    <param name="height" value="480"/>
    <param name="fps" value="10"/>
    <param name="angle" value="90"/>

    <!-- 相机参数 -->
    <param name="camera_name" value="rgb_cam"/>
    <param name="camera_info_url" value="file:///home/dut/lidar6/src/rgb_cam/config/rgb_cam.yaml"/>
  </node>
</launch>
